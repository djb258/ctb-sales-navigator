# Environment Variables — Sales Navigator
# ==========================================
# DO NOT put real secrets in this file!
# This is for documentation only.
#
# All secrets are managed via Doppler:
#   doppler run -- npm run dev
#
# See: docs/ADR-002-doppler-secrets.md

# Doppler injects these at runtime:
COMPOSIO_API_KEY=
NEON_DATABASE_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Vite client-side vars (Doppler injects via `doppler run -- npm run build`):
VITE_NEON_DATABASE_URL=

# Hub Identity (from REGISTRY.yaml)
HUB_ID=HUB-SALES-NAV-20260130
HUB_NAME=sales-navigator

# DO NOT CREATE .env WITH REAL VALUES
# Use: doppler run -- <command>
